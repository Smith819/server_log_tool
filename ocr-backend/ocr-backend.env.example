# AutoGLM OCR backend environment overrides
# Point this backend instance at any frontend server you want to pair with.

AUTOGLM_FRONTEND_BASE_URL=https://frontend.example.com:39283

# Backend API listener overrides.
AUTOGLM_OCR_API_ENABLED=true
AUTOGLM_OCR_API_HOST=0.0.0.0
AUTOGLM_OCR_API_PORT=39384
AUTOGLM_OCR_API_PUBLIC_BASE_URL=https://ocr-backend.example.com:39384
AUTOGLM_OCR_API_AUTH_TOKEN=

# Sync behavior overrides.
AUTOGLM_OCR_SYNC_ENABLED=true
AUTOGLM_OCR_VERIFY_SSL=true
